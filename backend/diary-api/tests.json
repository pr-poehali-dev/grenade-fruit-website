{
  "tests": [
    {
      "name": "Healthcheck",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"status": "ok"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login parent1",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "parent1", "password": "parent1pass"},
      "expectedStatus": 200,
      "expectedBody": {"role": "parent"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login teacher",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "Анна Сергеевна", "password": "teacher2024"},
      "expectedStatus": 200,
      "expectedBody": {"role": "teacher"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get classes",
      "method": "GET",
      "path": "/?action=get_classes",
      "expectedStatus": 200,
      "expectedBody": {"id": 1},
      "bodyMatcher": "array_contains"
    },
    {
      "name": "Get students",
      "method": "GET",
      "path": "/?action=get_students&class_id=14",
      "expectedStatus": 200,
      "expectedBody": {"full_name": "Алёша Петров"},
      "bodyMatcher": "array_contains"
    }
  ]
}